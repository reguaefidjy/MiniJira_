NODE_ENV=development
PORT=3000
DATABASE_URL=./minijira.db
CORS_ORIGIN=http://localhost:5173

# IMPORTANTE: Generar valores seguros con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REEMPLAZAR_CON_SECRETO_ALEATORIO_64_BYTES
JWT_REFRESH_SECRET=REEMPLAZAR_CON_SECRETO_ALEATORIO_64_BYTES
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/callback
# Endpoints del proveedor OAuth (ej. Google: accounts.google.com/o/oauth2/token, openidconnect.googleapis.com/v1/userinfo)
OAUTH_TOKEN_URL=
OAUTH_USERINFO_URL=

RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=noreply@example.com
WORKER_INTERVAL_MS=30000
